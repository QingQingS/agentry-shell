# ── LLM ──────────────────────────────────────────────────────
LLM_PROVIDER=openai
SMART_LLM_MODEL=gpt-4o
FAST_LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.7

# API Keys（按使用的 Provider 填写）
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...
DEEPSEEK_API_KEY=...

# ── Agent ─────────────────────────────────────────────────────
# 指定要加载的 Agent 类，格式：module.path.ClassName
AGENT_CLASS=agents.echo_agent.EchoAgent

# ── Retriever ─────────────────────────────────────────────────
# 检索源，逗号分隔多选：arxiv（无需 Key）/ tavily（需 TAVILY_API_KEY）/ local_file
RETRIEVER=arxiv,tavily
TAVILY_API_KEY=tvly-...

# ── Server ────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ── 日志 ──────────────────────────────────────────────────────
VERBOSE=true
